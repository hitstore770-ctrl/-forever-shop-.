rules_version = '2';

// Reference Firestore Security Rules — deploy with
// `firebase deploy --only firestore:rules` once a Firebase project is
// connected.
//
// Auth model: the /admin dashboard is gated by a shared passcode
// (lib/admin-auth.ts), NOT Firebase Auth — so `request.auth` is always null
// here. Admin WRITES therefore never come from the browser; they go through
// server-side Server Actions using the Firebase Admin SDK (a service
// account), which BYPASSES these rules entirely. That lets us deny all
// direct client writes below while the admin CMS still works.
//
// Public collections stay world-readable (the site reads them
// unauthenticated); the contact form is the one public write.
service cloud.firestore {
  match /databases/{database}/documents {
    // CMS content — public read, no direct client writes (the admin SDK
    // bypasses rules for the passcode-gated Server Actions).
    match /schedule/{itemId} {
      allow read: if true;
      allow write: if false;
    }
    match /staff/{memberId} {
      allow read: if true;
      allow write: if false;
    }
    match /gallery/{photoId} {
      allow read: if true;
      allow write: if false;
    }
    match /events/{eventId} {
      allow read: if true;
      allow write: if false;
    }

    match /donations/{donationId} {
      allow read: if true;
      allow write: if false;
    }

    match /contactSubmissions/{submissionId} {
      // Anyone can submit the Contact page's form; only the admin (via the
      // Admin SDK) can read/modify the resulting list.
      allow create: if true;
      allow read, update, delete: if false;
    }

    match /kuntresim/{kuntresId} {
      allow read: if true;
      allow write: if false;
    }

    // TODO: when /admin/gallery and /admin/events get real CRUD, add
    // matching collections here (allow read: if true; allow write: if false).
  }
}
