# Copy this file to .env.local and fill in your Firebase project's config
# (Project settings -> General -> Your apps -> SDK setup and configuration).
# These are all NEXT_PUBLIC_ because the Firebase client SDK runs in the
# browser — none of these values are secret on their own (access is governed
# by Firestore/Storage security rules, not by hiding this config).
#
# If any of these are missing, the app falls back to local mock data instead
# of querying Firestore — see lib/firebase.ts.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-only — used by app/api/checkout/confirm to notify the admin's
# WhatsApp bot of a new dedication. Leave unset to just log the payload
# instead of sending a real request (see lib/whatsapp-notify.ts).
WHATSAPP_WEBHOOK_URL=

# The site's real production domain (no trailing slash), e.g.
# https://www.our-yeshiva.org — used to build absolute Open Graph/Twitter
# image URLs (see app/layout.tsx). Falls back to localhost when unset.
NEXT_PUBLIC_SITE_URL=

# --- Admin dashboard (/admin) ---------------------------------------------
# Single shared passcode for the /admin login. SERVER-ONLY — do NOT prefix
# with NEXT_PUBLIC_, or the code would ship to the browser bundle. Set/change
# it straight from Vercel's Environment Variables (Project Settings ->
# Environment Variables) — no code change or redeploy of source needed; a
# redeploy to pick up the new value is enough. Rotating it also invalidates
# every existing admin session. If unset, /admin/login shows a clear
# "not configured" message. See lib/admin-auth.ts.
ADMIN_ACCESS_CODE=
